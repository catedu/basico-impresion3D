docs":{"2diseno/diseno3d.html":{"ref":"2diseno/diseno3d.html","tf":1.7101449275362317}}}}}}}}},"length":336},"corpusTokens":["1.1.","1.2.","1.3","1.4","100%","2.1","3","3d","4.0","aconsejamo","anterior","anterior.","aprendizaj","aquí","autor","bajo","bien","bloqu","básica","básico","circuito","common","como","compartirigu","compartirlo,","computacional.","con","concepto","conseguida","conseguida,","contenido","coordinación","creación","crear","creativ","crédito","cualquier","curso","curso.","curva","cámara","código","código.","de","desventaja","detección","diseñar","diseño","dispositivo","distribuy","ejemplo","ejemplo.","ejemplo:","el","electrónica","electrónico","electrónicos,","elegido","elementos.","embeberlo","en","encuadr","error","es","est","está","explicación","facilidad","facilita","favor","forma","gráfica","gráfica.","gráfico.","hemo","herramienta","impres","impresión","interfaz","internacion","introducción","items,","javier","la","lenguaj","licencia","license.","lo","lugar","mejor","metodología","modelo","montaje:","muy","nc","no","nocomerci","nuestro","o","objetivo","objeto","observación","ofrec","onlin","online.","online:","para","paso","patrón.","peiró","pensamiento","permit","permiten","personalizado:","pieza","poca","por","portatil","posibilidad","posibl","practica","programa","programación","programar","programarlo","publicarlo,","pued","que","quintana","qué","real.","realizar","reconocimiento","resultado","rápida","sa.","satisfactorios.","se","sencilla","sencillo","sencillos,","ser","si","siguen","simulación","simularlos.","soporte.catedu.","su","suma","sólo","tapa","tenemo","tien","tinkercad","tipo","toda","trataremo","un","una","utilando","utilizarlo","va","ve","ventaja","visión","visto","visualización","válido","web","y","ángulo"],"pipeline":["stopWordFilter","stemmer"]},"store":{"./":{"url":"./","title":"Introducción","keywords":"","body":"IMPRESIÓN BÁSICA EN 3D CON TINKERCAD\n\nObjetivos\n\nRealizar un diseño sencillo 3D en Tinkercad\nConceptos básicos en impresión 3D\n\nMetodologías\n\nDiseño paso a paso de una pieza sencilla\nExplicación de su impresión en 3D\n\nIMPRESION BÁSICA 3D por Javier Quintana Peiró bajo licencia Creative Commons Reconocimiento-NoComercial-CompartirIgual 4.0 Internacional License.\n\n"},"1tinkercad/tinkercad.html":{"url":"1tinkercad/tinkercad.html","title":"1.1. Qué es","keywords":"","body":"TINKERCAD\nTINKERCAD es un lugar web que tiene 3 herramientas sencillas online:\n\nHerramienta de creación de modelos 3D\nPrograma de simulación de circuitos electrónicos\nDiseño\nProgramación\nSimulación\n\n\nProgramación para impresión 3D\n\nIMPRESION BÁSICA 3D por Javier Quintana Peiró bajo licencia Creative Commons Reconocimiento-NoComercial-CompartirIgual 4.0 Internacional License.\n\n"},"1tinkercad/diseno.html":{"url":"1tinkercad/diseno.html","title":"1.2. Programa de diseño","keywords":"","body":"HERRAMIENTA DISEÑO TINKERCAD\nEs una herramienta online muy sencilla para crear objetos 3D con suma facilidad y una curva de aprendizaje muy rápida con resultados satisfactorios. Es la herramienta que hemos elegido para este curso\n\nNuestro objetivo va a ser realizar un tapa cámara web para el portatil paso a paso personalizado:\n\nIMPRESION BÁSICA 3D por Javier Quintana Peiró bajo licencia Creative Commons Reconocimiento-NoComercial-CompartirIgual 4.0 Internacional License.\n\n"},"1tinkercad/simulacionelectronica.html":{"url":"1tinkercad/simulacionelectronica.html","title":"1.3 Simulación electrónica","keywords":"","body":"Simulación electrónica\nTinkercad ofrece la posibilidad de diseñar nuestros circuitos electrónicos, programarlos y simularlos. Se ve mejor en este ejemplo:\n\n\nVentajas\n\nLa interfaz gráfica está muy bien conseguida, la visualización de los circuitos electrónicos está muy bien conseguida y muy real.\nToda la herramienta es 100% online.\nPuedes programar el dispositivo de forma gráfica.\nPermite publicarlo, compartirlo, embeberlo como hemos visto en el ejemplo anterior.\n\nDesventajas\n\nSólo es válido para circuitos sencillos, tiene pocas posibilidades y elementos.\nNo es posible una programación con código.\n\nIMPRESION BÁSICA 3D por Javier Quintana Peiró bajo licencia Creative Commons Reconocimiento-NoComercial-CompartirIgual 4.0 Internacional License.\n\n"},"1tinkercad/codigo.html":{"url":"1tinkercad/codigo.html","title":"1.4 Bloques de código","keywords":"","body":"BLOQUES DE CÓDIGO\n\nLos bloques de código nos permiten diseñar objetos 3D utilando un lenguaje sencillo gráfico.\n\nSe practica el pensamiento computacional.\nFacilita la creación de objetos 3D que siguen un patrón.\n\nAconsejamos utilizarlo si tenemos de objetivo los anteriores items, no lo trataremos en el curso. Aquí tienes un ejemplo.\n\n\n\n\nIMPRESION BÁSICA 3D por Javier Quintana Peiró bajo licencia Creative Commons Reconocimiento-NoComercial-CompartirIgual 4.0 Internacional License.\n\n"},"2diseno/diseno3d.html":{"url":"2diseno/diseno3d.html","title":"2.1 Ángulo de visión y encuadre","keywords":"","body":"2.1 Ángulo de visión y encuadre\nIMPRESION BÁSICA 3D por Javier Quintana Peiró bajo licencia Creative Commons Reconocimiento-NoComercial-CompartirIgual 4.0 Internacional License.\n\n"},"creditos.html":{"url":"creditos.html","title":"Créditos","keywords":"","body":"Autores\nCoordinación y montaje: \nCualquier observación o detección de error por favor aquí soporte.catedu.es\nLos contenidos se distribuye bajo licencia Creative Commons tipo BY-NC-SA.\n\n\n\n\n\n\nIMPRESION BÁSICA 3D por Javier Quintana Peiró bajo licencia Creative Commons Reconocimiento-NoComercial-CompartirIgual 4.0 Internacional License.\n\n"}}}